{
  "name": "unit-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "edge:check": "deno check --config supabase/functions/deno.json supabase/functions/add-property-to-admin/index.ts supabase/functions/complete-onboarding/index.ts supabase/functions/create-promotion-checkout-session/index.ts supabase/functions/delete-account/index.ts supabase/functions/expire-promotions/index.ts supabase/functions/invite-tenant/index.ts supabase/functions/issue-refund/index.ts supabase/functions/send-push-notification/index.ts",
    "db:test:security": "supabase test db supabase/tests/security_rls.test.sql",
    "brand-lint": "bash -c '! grep -rn --include=\"*.tsx\" -E \"bg-white|bg-gray-|text-gray-|border-gray-|text-black[^-]|bg-black([^/]|$)\" app components && ! grep -rn --include=\"*.tsx\" -E \"font-arcadia|font-bold|font-medium|font-nunito-bold|font-lora-bold\" app components && ! grep -rn --include=\"*.tsx\" -E \"text-xs|text-lg|text-xl|text-4xl\" app components && echo brand-lint-clean'",
    "release:check-env": "node scripts/check-release-env.mjs",
    "release:check": "npm run release:check-env && npm run typecheck && npm run brand-lint && npm test && npx expo-doctor",
    "release:ios:build": "eas build --platform ios --profile production",
    "release:ios:submit": "eas submit --platform ios --profile production",
    "release:ios:testflight": "eas build --platform ios --profile production --submit",
    "appstore:auth:check": "fastlane ios appstore_auth_check",
    "testflight:distribute": "fastlane ios distribute_testflight",
    "test:watch": "jest --watch",
    "build:web": "npx expo export --platform web",
    "start:web": "npx serve dist",
    "db:seed": "tsx scripts/generate-seed-sql.ts",
    "test:e2e": "JAVA_HOME=/opt/homebrew/opt/openjdk@21 MAESTRO_CLI_NO_ANALYTICS=1 MAESTRO_CLI_ANALYSIS_NOTIFICATION_DISABLED=true ~/.maestro/bin/maestro test maestro/flows/",
    "maestro": "JAVA_HOME=/opt/homebrew/opt/openjdk@21 MAESTRO_CLI_NO_ANALYTICS=1 MAESTRO_CLI_ANALYSIS_NOTIFICATION_DISABLED=true ~/.maestro/bin/maestro"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "can-promise": "^0.0.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.2.3",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "tailwindcss": "^3.4.19",
    "victory-native": "^36.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "autoprefixer": "^10.5.0",
    "babel-preset-expo": "~54.0.10",
    "deno": "^2.7.14",
    "expo-mcp": "~0.2.1",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "^19.1.0",
    "supabase": "^2.89.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "xlsx": "^0.18.5"
  },
  "private": true
}
