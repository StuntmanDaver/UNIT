EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_APP_URL=unit://

# Sentry (optional). If EXPO_PUBLIC_SENTRY_DSN is unset, lib/sentry.ts
# initializes Sentry with dsn: undefined and the SDK silently no-ops —
# the app runs fine but you get zero crash reports.
#
# Get values at: https://sentry.io/settings/<org>/projects/<project>/keys/
EXPO_PUBLIC_SENTRY_DSN=

# Build-time only. Used by the @sentry/react-native config plugin to
# upload source maps so production crash stack traces are readable.
# Not required for runtime crash capture. Currently unused because
# eas.json sets SENTRY_DISABLE_AUTO_UPLOAD=true on every profile —
# remove that flag from eas.json when you set these.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
