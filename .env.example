EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_APP_URL=unit://
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_SUPPORT_EMAIL=support@unitapp.com

# App identity selected by app.config.ts. Use staging for TestFlight/internal QA
# and production for the client-owned live app.
APP_VARIANT=development

# Sentry. Required for staging/production release rehearsals.
# Get values at: https://sentry.io/settings/<org>/projects/<project>/keys/
EXPO_PUBLIC_SENTRY_DSN=

# Build-time only. Used by the @sentry/react-native config plugin to
# upload source maps so production crash stack traces are readable.
# Not required for runtime crash capture, but required by release:check
# because staging and production EAS profiles enable source-map upload.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
