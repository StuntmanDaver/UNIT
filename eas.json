{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_ENV": "development",
        "EXPO_PUBLIC_APP_URL": "unit-dev://",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_ENV": "staging",
        "EXPO_PUBLIC_APP_URL": "unit-staging://",
        "SENTRY_DISABLE_AUTO_UPLOAD": "false"
      }
    },
    "preview": {
      "extends": "staging"
    },
    "preview-simulator": {
      "extends": "staging",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_APP_URL": "unit://",
        "SENTRY_DISABLE_AUTO_UPLOAD": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ketchel.david@gmail.com",
        "ascAppId": "6767079612", 
        "appleTeamId": "KLJ7P6JXK7"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
  }
}
